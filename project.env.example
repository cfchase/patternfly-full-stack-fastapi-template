# Project Identity Configuration
# This file defines project-specific settings for container images and Kubernetes deployments.
#
# Setup Options:
#   1. Interactive: Run ./scripts/setup-project.sh
#   2. Manual: Copy to project.env, edit values, then run ./scripts/update-k8s-images.sh
#
# This file (project.env) should be committed to git after configuration.

# Project name - used for container image naming
# Must be lowercase, alphanumeric with hyphens only (e.g., my-app, cool-project)
# Images will be named: {REGISTRY}/{PROJECT_NAME}-backend and {REGISTRY}/{PROJECT_NAME}-frontend
PROJECT_NAME=my-app

# Container registry - where images will be pushed
# Examples: quay.io/myorg, docker.io/myuser, ghcr.io/myorg
REGISTRY=quay.io/myorg

# Namespace prefix for Kubernetes deployments (optional)
# If empty, PROJECT_NAME is used
# Namespaces will be: {NAMESPACE_PREFIX}-dev and {NAMESPACE_PREFIX}-prod
NAMESPACE_PREFIX=
